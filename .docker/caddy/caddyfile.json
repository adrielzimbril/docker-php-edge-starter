        },
        "tls": {
            "automation": {
                "policies": [
                    {
                        "issuers": [
                            {
                                "challenges": {
                                    "dns": {
                                        "provider": {
                                            "api_token": "{env.CLOUDFLARE_API_TOKEN}",
                                            "name": "cloudflare"
                                        }
                                    }
                                },
                                "email": "{env.CLOUDFLARE_API_MAIL}",
                                "module": "acme"
                            },
                            {
                                "challenges": {
                                    "dns": {
                                        "provider": {
                                            "api_token": "{env.CLOUDFLARE_API_TOKEN}",
                                            "name": "cloudflare"
                                        }
                                    }
                                },
                                "email": "{env.CLOUDFLARE_API_MAIL}",
                                "module": "zerossl"
                            }
                        ]
                    }
                ]
            }
        }
    },
    "logging": {
        "logs": {
            "default": {
                "exclude": [
                    "http.log.access.log0",
                    "http.log.access.log1",
                    "http.log.access.log2",
                    "http.log.access.log3",
                    "http.log.access.log4"
                ]
            },
            "log0": {
                "include": [
                    "http.log.access.log0"
                ],
                "writer": {
                    "filename": "/var/log/caddy/access_oricode_redirection.log",
                    "output": "file"
                }
            },
            "log1": {
                "include": [
                    "http.log.access.log1"
                ],
                "writer": {
                    "filename": "/var/log/caddy/access_oricode_subdomain.log",
                    "output": "file"
                }
            },
            "log2": {
                "include": [
                    "http.log.access.log2"
                ],
                "writer": {
                    "filename": "/var/log/caddy/access_oricode_tenant_subdomain.log",
                    "output": "file"
                }
            },
            "log3": {
                "include": [
                    "http.log.access.log3"
                ],
                "writer": {
                    "filename": "/var/log/caddy/access_oricode_server_subdomain.log",
                    "output": "file"
                }
            },
            "log4": {
                "include": [
                    "http.log.access.log4"
                ],
                "writer": {
                    "filename": "/var/log/caddy/access_oricode_443.log",
                    "output": "file"
                }
            }
        }
    }
